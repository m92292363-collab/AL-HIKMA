// scripts/seed-admin.js
// Run this ONCE to create your admin account in Netlify DB
//
// 1. npm install
// 2. Create .env:  NETLIFY_DATABASE_URL=...  JWT_SECRET=...
// 3. Edit credentials below
// 4. node scripts/seed-admin.js

require('dotenv').config();
const { neon } = require('@netlify/neon');
const bcrypt = require('bcryptjs');

const sql = neon();

async function seed() {
    console.log('🔌 Connecting to Netlify DB...');

    await sql`
        CREATE TABLE IF NOT EXISTS students (
            id SERIAL PRIMARY KEY,
            student_id VARCHAR(50) UNIQUE NOT NULL,
            name VARCHAR(200) NOT NULL,
            email VARCHAR(200) UNIQUE NOT NULL,
            password VARCHAR(255) NOT NULL,
            faculty VARCHAR(200),
            department VARCHAR(200),
            year VARCHAR(10),
            role VARCHAR(20) DEFAULT 'student',
            created_at TIMESTAMP DEFAULT NOW(),
            updated_at TIMESTAMP DEFAULT NOW()
        )
    `;

    await sql`
        CREATE TABLE IF NOT EXISTS results (
            id SERIAL PRIMARY KEY,
            student_id VARCHAR(50) NOT NULL REFERENCES students(student_id) ON DELETE CASCADE,
            subject VARCHAR(200) NOT NULL,
            score NUMERIC(5,2),
            grade VARCHAR(5),
            semester VARCHAR(50),
            academic_year VARCHAR(20),
            created_at TIMESTAMP DEFAULT NOW(),
            updated_at TIMESTAMP DEFAULT NOW()
        )
    `;

    await sql`
        CREATE TABLE IF NOT EXISTS staff (
            id SERIAL PRIMARY KEY,
            staff_id VARCHAR(50) UNIQUE NOT NULL,
            name VARCHAR(200) NOT NULL,
            email VARCHAR(200) UNIQUE NOT NULL,
            password VARCHAR(255) NOT NULL,
            faculty VARCHAR(200),
            role VARCHAR(20) DEFAULT 'staff',
            created_at TIMESTAMP DEFAULT NOW(),
            updated_at TIMESTAMP DEFAULT NOW()
        )
    `;

    await sql`
        CREATE TABLE IF NOT EXISTS login_attempts (
            id SERIAL PRIMARY KEY,
            identifier VARCHAR(200) NOT NULL,
            attempts INTEGER DEFAULT 0,
            locked_until TIMESTAMP,
            updated_at TIMESTAMP DEFAULT NOW()
        )
    `;

    console.log('✅ Tables ready.\n');

    // ─── ADMIN ACCOUNT ───────────────────────────────
    // ⚠️ Change these credentials before running!
    const admin = {
        staffId: 'admin@alhikma.edu',
        name: 'System Administrator',
        email: 'admin@alhikma.edu',
        password: 'ChangeMe@2024!',    // ⚠️ Change this!
        faculty: null,                  // null = access to ALL faculties
        role: 'admin',
    };

    const [existingAdmin] = await sql`SELECT id FROM staff WHERE staff_id = ${admin.staffId}`;
    if (!existingAdmin) {
        const hashed = await bcrypt.hash(admin.password, 10);
        await sql`
            INSERT INTO staff (staff_id, name, email, password, faculty, role)
            VALUES (${admin.staffId}, ${admin.name}, ${admin.email}, ${hashed}, ${admin.faculty}, 'admin')
        `;
        console.log('✅ Admin account created!');
        console.log(`   ID       : ${admin.staffId}`);
        console.log(`   Password : ${admin.password}`);
    } else {
        console.log('ℹ️  Admin already exists. Skipped.');
    }

    // ─── EXAMPLE STAFF ACCOUNTS ──────────────────────
    // Add one staff per faculty. Each can only manage their faculty.
    // Remove or edit these as needed.
    const staffAccounts = [
        { staffId: 'edu.staff@alhikma.edu',    name: 'Dr. Education Staff',  email: 'edu.staff@alhikma.edu',    password: 'Staff@Edu2024!',    faculty: 'Faculty of Education' },
        { staffId: 'arts.staff@alhikma.edu',   name: 'Dr. Arts Staff',       email: 'arts.staff@alhikma.edu',   password: 'Staff@Arts2024!',   faculty: 'Faculty of Arts and Humanity' },
        { staffId: 'quran.staff@alhikma.edu',  name: 'Dr. Quran Staff',      email: 'quran.staff@alhikma.edu',  password: 'Staff@Quran2024!',  faculty: 'Faculty of Quran and Islamic Studies' },
        { staffId: 'law.staff@alhikma.edu',    name: 'Dr. Law Staff',        email: 'law.staff@alhikma.edu',    password: 'Staff@Law2024!',    faculty: 'Faculty of Shariaa and Law' },
    ];

    console.log('\n── Staff Accounts ──');
    for (const s of staffAccounts) {
        const [ex] = await sql`SELECT id FROM staff WHERE staff_id = ${s.staffId}`;
        if (!ex) {
            const hashed = await bcrypt.hash(s.password, 10);
            await sql`
                INSERT INTO staff (staff_id, name, email, password, faculty, role)
                VALUES (${s.staffId}, ${s.name}, ${s.email}, ${hashed}, ${s.faculty}, 'staff')
            `;
            console.log(`✅ Created: ${s.staffId}  (${s.faculty})`);
        } else {
            console.log(`ℹ️  Exists : ${s.staffId}`);
        }
    }

    console.log('\n────────────────────────────────────────');
    console.log('🔒 Login URL (admin + staff): yoursite.netlify.app/management.html');
    console.log('⚠️  Change all default passwords after first login!');
    console.log('────────────────────────────────────────\n');
    process.exit(0);
}

seed().catch(err => {
    console.error('❌ Error:', err.message);
    process.exit(1);
});
